# Transfera v2 — Git Ignore

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
*.egg
.eggs/

# --- Runtime data ---
backend/data/db/
backend/data/exports/
backend/data/thumbnails/
backend/data/local_secret.json
*.db
*.db-wal
*.db-shm

# --- Node.js ---
node_modules/
frontend/dist/
frontend/dist-electron/
frontend/electron/dist-electron/
frontend/release/
frontend/*.tsbuildinfo
frontend/vite.config.d.ts
frontend/vite.config.js
frontend/python-bin/
frontend/python-embed.zip
*.pfx


# --- Environment ---
.env
.env.local
.env.*.local
*.env
venv/
.venv/

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- OS ---
desktop.ini
._*

# --- Logs ---
*.log
backend/data/logs/
backend.err

# --- Cache ---
.cache/
frontend/.cache/
backend/data/cache/

# --- Partial / temp files ---
*.partial
*.tmp

# --- Electron build artifacts ---
frontend/release/
*.blockmap
SHA256SUMS.txt

# --- Test databases (created during test runs) ---
backend/data/db/test_*.db*

# --- ExifTool downloaded binaries ---
backend/bin/exiftool/

# --- Native build artifacts ---
backend/bin/wpd_helper.exe
backend/bin/wpd_helper_test.exe
backend/bin/wpd_helper/
backend/bin_debug/
native/wpd_helper/build/
native/wpd_helper/.cache/
*.obj
*.pdb
*.ilk
*.exp

# --- Documentation (design spec, not runtime code) ---
DESIGN.md

# --- Misc ---
*.bak
*.backup
coverage/
htmlcov/
.coverage
coverage.xml
digest.txt
.agents/
AGENTS.md
skills-lock.json
