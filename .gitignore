# Transfera v2 — Git Ignore

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
*.egg
.eggs/

# --- SQLite databases ---
*.db
*.db-wal
*.db-shm

# --- Node.js ---
node_modules/
frontend/dist/
frontend/dist-electron/
frontend/electron/dist-electron/
frontend/release/

# --- Environment ---
.env
.env.local
.env.*.local
*.env
venv/
.venv/

# --- IDE / Editor ---
.vscode/
pyproject.toml
pyrightconfig.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- OS ---
desktop.ini
._*

# --- Logs ---
*.log
backend/data/logs/

# --- Cache ---
.cache/
frontend/.cache/
backend/data/cache/

# --- Partial / temp files ---
*.partial
*.tmp

# --- Electron build artifacts ---
frontend/release/
*.blockmap

# --- Test databases (created during test runs) ---
backend/data/db/test_*.db*

# --- ExifTool downloaded binaries ---
backend/bin/exiftool/

# --- Native build artifacts ---
backend/bin_debug/
native/wpd_helper/build/
native/wpd_helper/.cache/
*.obj

# --- Misc ---
*.bak
*.backup
coverage/
htmlcov/
.coverage
coverage.xml
digest.txt
.agents/
AGENTS.md
skills-lock.json
Transfera_Architecture_Spec_v2.pdf

# Exclude internal backend testing scripts
backend/tests/
test_dest/
test_source/
opencode.json
