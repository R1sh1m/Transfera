{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./dist-electron",
    "rootDir": ".",
    "declaration": false,
    "sourceMap": true
  },
  "include": ["main.ts", "preload.ts"]
}
